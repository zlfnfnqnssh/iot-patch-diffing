# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Local tooling and editor state
.claude/*
# 팀 공유 대상은 git 추적 (개별 예외)
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**
!.claude/commands/
!.claude/commands/**
!.claude/settings.json
# .claude/settings.local.json 은 개인 설정이라 계속 무시됨
/--help

# Analysis inputs / outputs
/data/*
!/data/.gitkeep
# 팀 핸드오프 문서는 git 추적
!/data/handoff/
/data/handoff/artifacts/
# CVE ground truth (팀장 공유용)
!/data/cve/
/logs/
/output/*
!/output/.gitkeep
/results/

# 개인 임시 작업 파일
/tmp/

# Reports: keep reusable tooling, skip generated outputs and personal notes
/report/__pycache__/
/report/*.pdf
/report/weekly-report-20*.md
/report/*.txt

# Commercial reverse-engineering tools and plugins
/Hex-Rays IDA Professional*/
/bindiff8_ida.dll
/bindiff8_ida64.dll
/binexport12_ida.dll
/binexport12_ida64.dll

# IDA / BinDiff generated artifacts
*.id0
*.id1
*.id2
*.id3
*.idb
*.i64
*.nam
*.til
*.BinExport
*.BinDiff

# Databases and local caches
/src/db/*.db
/Patch-Learner-main/src/db/*.db
*.sqlite

# Embedded tool repos: keep source, skip nested git metadata and generated files
/tools/tp-link-decrypt/.git/
/tools/tp-link-decrypt/.git.embedded-backup/
/tools/tp-link-decrypt/bin/
/tools/tp-link-decrypt/example.jpg
/tools/tp-link-decrypt-robbins/.git/
/tools/tp-link-decrypt-robbins/.git.embedded-backup/
/tools/tp-link-decrypt-robbins/tmp/
/tools/tp-link-decrypt-robbins/example.jpg
